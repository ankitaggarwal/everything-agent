# everything-agent secrets -- the ONE place for all API keys.
# Copy to .env and fill in what you use. Never commit your real .env (gitignored).
# Everything defaults to mock/keyless, so you only need the keys for the backends
# you actually turn on in config.yaml / config.reachy.yaml.

# ── Core (the robot's brain + voice) ─────────────────────────────────────────
# Router (Haiku) + the `fast` tool-using brain. Required for real conversation.
ANTHROPIC_API_KEY=
# Cartesia powers BOTH voice (Sonic TTS) and hearing (Ink-Whisper STT).
CARTESIA_API_KEY=
CARTESIA_VOICE_ID=
# Only for the claude_sdk brain in `auth: login` mode (unlocks Opus via your sub).
CLAUDE_CODE_OAUTH_TOKEN=

# ── Capabilities (all optional; modules degrade gracefully without them) ──────
# Web search / current info / news -- Tavily, free tier (1000 searches/mo, no card).
#   Get a key at https://app.tavily.com  ->  enables the `web_search` module.
TAVILY_API_KEY=
# Weather uses Open-Meteo, which is KEYLESS -- no key needed for the weather module.

# ── Optional backends you mentioned (not required; wire in when you want them) ─
# Long-term memory backend (mem0). Free tier available. For a future `mem0` memory backend.
MEM0_API_KEY=
# Upstash Redis (serverless, free tier) -- optional durable store for reminders/memory.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Hugging Face (model downloads / wake-word).
HF_TOKEN=

# ── Other providers (only if you switch a backend to them) ───────────────────
# Tier-1 router alternative (config: brain.router.backend = gemini).
GEMINI_API_KEY=
